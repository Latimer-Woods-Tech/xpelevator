# XPElevator — environment variables
# Copy to `.env` and fill in. Never commit the filled-in .env (it is gitignored).
# In production these are set as Cloudflare Worker secrets, not from this file.

# ── Required ──────────────────────────────────────────────────────────────────

# Neon Postgres connection string. All database queries fail without this.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth (Auth.js) session-signing secret. Generate with: openssl rand -base64 32
# /api/auth/session returns 500 without this.
AUTH_SECRET=""

# Groq API key for simulated-customer replies and session scoring.
GROQ_API_KEY=""

# ── Authentication (recommended for production) ───────────────────────────────

# GitHub OAuth. Production sign-in uses OAuth; set both to enable the provider.
# Callback URL: https://<your-domain>/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Passwordless email sign-in (the Credentials provider) is dev/demo only and is
# excluded in production. Set to "true" ONLY for a demo deployment that accepts
# the risk of email-only, unverified sign-in.
# AUTH_CREDENTIALS_ENABLED="false"

# Require an already-existing user for Credentials sign-in (disables the
# dev-only auto-create). No effect in production, where auto-create is always off.
# CREDENTIALS_REQUIRE_EXISTING="false"

# ── Voice / phone (optional — the PHONE modality) ─────────────────────────────

# Telnyx Call Control credentials. Phone simulations are disabled without these.
TELNYX_API_KEY=""
TELNYX_CONNECTION_ID=""
TELNYX_FROM_NUMBER=""            # your Telnyx number, E.164 e.g. +12125550100
TELNYX_WEBHOOK_URL=""            # https://<your-domain>/api/telnyx/webhook

# Telnyx Ed25519 public key for webhook signature verification. REQUIRED in
# production — the webhook fails closed (rejects all events) if this is unset.
TELNYX_PUBLIC_KEY=""

# ── Local test tooling (optional) ─────────────────────────────────────────────

# Point the smoke suite (tests/smoke) at a live deployment. When unset the smoke
# tests skip; when set to an unreachable host they fail loudly.
# SMOKE_BASE_URL="https://xpelevator-sim.pages.dev"
