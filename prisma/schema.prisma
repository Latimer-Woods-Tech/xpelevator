generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Organisation / multi-tenant models ──────────────────────────────────────────

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  plan        OrgPlan  @default(FREE)
  kind        OrgKind  @default(STANDALONE)
  parentOrgId String?  @map("parent_org_id") // set when this org is a CLIENT owned by an OPERATOR
  createdAt   DateTime @default(now()) @map("created_at")

  // White-label operator branding (issue #16, Phase 4, R-044). All nullable —
  // NULL means "fall back to the platform default". Colors are stored as
  // normalized lowercase `#rrggbb`; logoUrl is https-only. Validated at the API
  // layer (src/lib/branding.ts).
  brandDisplayName  String? @map("brand_display_name")
  brandLogoUrl      String? @map("brand_logo_url")
  brandPrimaryColor String? @map("brand_primary_color")
  brandAccentColor  String? @map("brand_accent_color")

  // Operator→client hierarchy (issue #16, Phase 4). A CLIENT org points at the
  // OPERATOR org that owns it; an OPERATOR org has many client children.
  parent   Organization?  @relation("OrgHierarchy", fields: [parentOrgId], references: [id])
  children Organization[] @relation("OrgHierarchy")

  users       User[]
  jobTitles   JobTitle[]
  scenarios   Scenario[]
  criteria    Criteria[]
  sessions    SimulationSession[]

  @@index([parentOrgId])
  @@map("organizations")
}

model User {
  id        String   @id @default(uuid())
  orgId     String?  @map("org_id")       // nullable — users without an org use personal workspace
  email     String   @unique
  name      String?
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  org      Organization? @relation(fields: [orgId], references: [id])
  sessions SimulationSession[]

  @@map("users")
}

model JobTitle {
  id          String   @id @default(uuid())
  orgId       String?  @map("org_id")       // null = global (available to all orgs)
  // NOTE: `name` uniqueness is org-scoped, not global — enforced by the partial
  // indexes `job_titles_org_name_key` (org-scoped) + `job_titles_global_name_key`
  // (legacy globals) in migration 20260712120000_add_pack_provenance. Prisma
  // can't express partial-predicate uniqueness in the schema, so no `@unique`
  // here; the DB is the source of truth for that constraint.
  name        String
  description String?
  // Pack-import provenance (migration 20260712120000): which starter pack this
  // role came from and at what catalog version. NULL for hand-authored roles.
  sourcePackId String? @map("source_pack_id")
  packVersion  Int?    @map("pack_version")
  createdAt   DateTime @default(now()) @map("created_at")

  org          Organization?       @relation(fields: [orgId], references: [id])
  scenarios    Scenario[]
  jobCriteria  JobCriteria[]
  sessions     SimulationSession[]

  @@map("job_titles")
}

model Scenario {
  id          String       @id @default(uuid())
  orgId       String?      @map("org_id")
  jobTitleId  String       @map("job_title_id")
  name        String
  description String?
  type        SimulationType
  script      Json         @default("{}")
  // Pack-import provenance (migration 20260712120000). `sourcePackId` +
  // `sourceScenarioKey` are the idempotency key for re-import — a partial unique
  // index `scenarios_org_pack_scenario_key` on (org_id, source_pack_id,
  // source_scenario_key) enforces one row per pack scenario per org. NULL for
  // hand-authored scenarios. `packVersion` stamps the catalog version imported.
  sourcePackId      String? @map("source_pack_id")
  sourceScenarioKey String? @map("source_scenario_key")
  packVersion       Int?    @map("pack_version")
  createdAt   DateTime     @default(now()) @map("created_at")

  org      Organization? @relation(fields: [orgId], references: [id])
  jobTitle JobTitle      @relation(fields: [jobTitleId], references: [id])
  sessions SimulationSession[]

  @@map("scenarios")
}

model Criteria {
  id          String   @id @default(uuid())
  orgId       String?  @map("org_id")
  name        String
  description String?
  weight      Int      @default(5)
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org         Organization? @relation(fields: [orgId], references: [id])
  jobCriteria JobCriteria[]
  scores      Score[]

  @@map("criteria")
}

model JobCriteria {
  id         String   @id @default(uuid())
  jobTitleId String   @map("job_title_id")
  criteriaId String   @map("criteria_id")

  jobTitle   JobTitle @relation(fields: [jobTitleId], references: [id])
  criteria   Criteria @relation(fields: [criteriaId], references: [id])

  @@unique([jobTitleId, criteriaId])
  @@map("job_criteria")
}

model SimulationSession {
  id         String           @id @default(uuid())
  orgId      String?          @map("org_id")         // populated when user belongs to an org
  userId     String?          @map("user_id")        // auth user id (string from NextAuth)
  dbUserId   String?          @map("db_user_id")     // FK to User.id when user record exists
  jobTitleId String           @map("job_title_id")
  scenarioId String           @map("scenario_id")
  type       SimulationType
  status     SessionStatus    @default(PENDING)
  // Recorded at end-of-session: SCORED | FAILED | NOT_SCORABLE.
  // NULL = pre-instrumentation (older completed rows); lets the manager report
  // distinguish a scoring-engine failure from a genuinely un-scored session.
  scoringStatus String?       @map("scoring_status")
  startedAt  DateTime?        @map("started_at")
  endedAt    DateTime?        @map("ended_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  org        Organization?    @relation(fields: [orgId], references: [id])
  dbUser     User?            @relation(fields: [dbUserId], references: [id])
  jobTitle   JobTitle         @relation(fields: [jobTitleId], references: [id])
  scenario   Scenario         @relation(fields: [scenarioId], references: [id])
  messages   ChatMessage[]
  scores     Score[]

  @@index([userId])
  @@index([jobTitleId])
  @@index([orgId])
  @@map("simulation_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  role      MessageRole
  content   String
  timestamp DateTime @default(now())

  session   SimulationSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@map("chat_messages")
}

model Score {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  criteriaId String   @map("criteria_id")
  score      Float
  feedback   String?
  scoredAt   DateTime @default(now()) @map("scored_at")

  session    SimulationSession @relation(fields: [sessionId], references: [id])
  criteria   Criteria          @relation(fields: [criteriaId], references: [id])

  @@index([sessionId])
  @@index([criteriaId])
  @@map("scores")
}

enum SimulationType {
  PHONE
  CHAT
  VOICE
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ABANDONED
}

enum MessageRole {
  CUSTOMER
  AGENT
}

enum UserRole {
  ADMIN
  MEMBER
}

enum OrgPlan {
  FREE
  PRO
  ENTERPRISE
}

enum OrgKind {
  STANDALONE // a plain tenant (today's default) — no parent, no children
  OPERATOR   // owns CLIENT orgs beneath it (the channel buyer)
  CLIENT     // owned by an OPERATOR
}
