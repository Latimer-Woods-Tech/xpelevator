{
  "name": "xpelevator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "seed": "tsx prisma/seed.ts",
    "pages:build": "npx @opennextjs/cloudflare build",
    "bundle:worker": "node scripts/bundle-worker.js",
    "preview": "npm run pages:build && npx wrangler dev",
    "deploy": "npm run pages:build && npx wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ui": "vitest run tests/ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --config vitest.ci.config.ts --coverage",
    "test:e2e": "tsx tests/e2e/full-simulation.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10",
    "eslint-config-next": "^16.2.10",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^7",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10",
    "wrangler": "^4"
  }
}
